# ==========================================
# Multi-Agent Research Platform — Environment
# ==========================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or set these as environment variables in your shell.
#
# ==========================================

# ==========================================
# REQUIRED
# ==========================================

# Groq API key for LLM inference.
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# MongoDB connection string.
# For Docker Compose (default):
#   mongodb://mongo:27017
# For local development:
#   mongodb://localhost:27017
MONGODB_URL=mongodb://mongo:27017

# MongoDB database name
DATABASE_NAME=multi_agent_platform

# ==========================================
# OPTIONAL — defaults provided
# ==========================================

# Application environment
ENVIRONMENT=production

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ChromaDB persistence directory
# (managed via Docker volume in production)
CHROMA_PERSIST_DIR=./chroma_data

# LLM Configuration
LLM_PROVIDER=groq
MODEL_NAME=llama-3.1-8b-instant
TEMPERATURE=0.1

# Token limits
DEFAULT_MAX_TOKENS=1000
SUMMARY_MAX_TOKENS=300
FACTCHECK_MAX_TOKENS=500
REPORT_MAX_TOKENS=1200

# Retrieval
MAX_SEARCH_RESULTS=5
MAX_ARTICLE_LENGTH=3000
REQUEST_TIMEOUT=10
MAX_RETRIES=3

# Hybrid Retrieval Weights
HYBRID_SEMANTIC_WEIGHT=0.7
HYBRID_KEYWORD_WEIGHT=0.3
HYBRID_RETRIEVAL_MULTIPLIER=3

# Evidence
MAX_CHUNKS_PER_SOURCE=2

# Vector Store
VECTOR_ENABLED=True
VECTOR_COLLECTION=research_chunks

# Embeddings
EMBEDDINGS_ENABLED=True
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=32

# Auth
JWT_SECRET=your-secret-key

# API
API_TITLE=Multi-Agent Research Platform
API_VERSION=1.0.0
DEBUG=False
